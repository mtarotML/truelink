# ---- Postgres ----
POSTGRES_USER=truelink
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=truelink

# ---- Backend ----
# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-long-random-hex-string
# Comma separated origins allowed to call the API (frontend + local dev)
# Include every origin you open in the browser (localhost vs 127.0.0.1 are different for cookies/OAuth)
CORS_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1
# Public base used to build photo URLs returned by the API
PUBLIC_MEDIA_BASE=/media
# Email that gets promoted to admin role on first Google sign-in
ADMIN_EMAIL=exemple@email.com

# ---- Google OAuth ----
# Create an OAuth client in Google Cloud Console (Web application)
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- NextAuth ----
# openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-long-random-base64-string
# Must match the exact URL you use in the browser (scheme + host + port), e.g. http://127.0.0.1
NEXTAUTH_URL=http://localhost

# ---- Frontend ----
# Public base the browser uses to hit the API through nginx
NEXT_PUBLIC_API_URL=/api

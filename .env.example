# ---- Docker Compose ----
# Dev  (direct access on :8000 / :3000, no reverse proxy):
#   docker compose up
#
# Prod (nginx reverse proxy only, backend/frontend not exposed to host):
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# Or uncomment the line below on the VM to avoid passing -f flags every time:
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml

# ---- Postgres ----
POSTGRES_USER=truelink
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=truelink

# ---- Backend ----
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-long-random-hex-string

# Comma-separated origins allowed to call the API.
#   Dev (direct):  http://localhost:3000,http://127.0.0.1:3000
#   Prod (nginx):  https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public base URL used to build photo URLs returned by the API.
#   Dev (direct):  http://localhost:8000/media
#   Prod (nginx):  /media
PUBLIC_MEDIA_BASE=http://localhost:8000/media

# Emails promoted to admin on first Google sign-in (comma-separated).
ADMIN_EMAIL=admin@example.com

# ---- Groq (LLM for fictive profile replies) ----
# Create a free API key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# ---- Google OAuth ----
# Create a Web application client in Google Cloud Console.
# Authorized redirect URIs:
#   Dev:  http://localhost:3000/api/auth/callback/google
#   Prod: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-long-random-base64-string

# Must match the exact URL opened in the browser (scheme + host + port).
#   Dev:  http://localhost:3000
#   Prod: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# ---- Frontend ----
# Public base URL the browser uses to reach the API.
#   Dev (direct):           http://localhost:8000
#   Prod (through nginx):   /api
NEXT_PUBLIC_API_URL=http://localhost:8000
